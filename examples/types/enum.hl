mod main

enum Shape {
    Rect(float width, float height)
    Circle(float radius)
}

fn [s Shape] toString() {
    switch s {
        Rect |width, height| => { return "R(" + width + ", " + height + ")" }
        Circle |radius| => { return "C(" + radius + ")" }
    }
}

fn main() {
    shape := Shape.Rect(5., 3.2)
    println(shape.toString())
}
