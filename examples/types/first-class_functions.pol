mod main

fn apply(int[] nums, fn(int) int f) int[] {
    result := []int
    for _, n in nums {
        result.append(f(n))
    }
    return result
}

fn main() {
    nums := [1, 2, 3, 4, 5]

    doubled := apply(nums, fn(x int) int {
        return x * 2
    })

    factor := 10
    scaled := apply(nums, fn(x int) int {
        return x * factor
    })

    println(doubled)
    println(scaled)
}
