mod main

struct Stack<T> {
    T[] items
}

fn [s Stack<T>] push(T item) {
    s.items.append(item)
}

fn [s Stack<T>] pop() T {
    return s.items.removeLast()
}

fn [s Stack<T>] empty() bool {
    return s.items.len == 0
}

fn main() {
    stack := new Stack<int>()
    stack.push(1)
    stack.push(2)
    println(stack.pop())
}
