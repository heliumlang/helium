mod main

alias Meters = float

fn [m Meters] Centimeters() float {
    return m * 100
}

alias Seconds = float

fn [s Seconds] Milliseconds() float {
    return m * 1000
}

fn metersPerSecond(Meters dist, Seconds time) float {
    return dist / time
}

fn cmPerMs(Meters dist, Seconds time) float {
    return dist.Centimeters() / time.Milliseconds()
}

fn main() {
    speed := metersPerSecond(100.0, 9.58)
    println(speed)

    speed = cmPerMs(100.0, 9.58)
    println(speed)
}
